rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to upload images to listings folder
    match /listings/{userId}/{allPaths=**} {
      allow read: if true;
      allow write, delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to upload profile pictures
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write, delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Chat images. Storage rules can't read Firestore, so they can't verify
    // "is this person in the conversation" - instead new uploads are pathed
    // under the uploader's UID and write/delete is scoped to that UID, so no
    // one can overwrite or delete someone else's image (previously ANY signed-
    // in user could delete images from ANY conversation). Read stays open
    // because images are shown via tokenized download URLs.
    match /chat-images/{conversationId} {
      match /{allPaths=**} {
        allow read: if true;
      }
      match /{userId}/{fileName} {
        allow write, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
