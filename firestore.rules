rules_version = "2";
service cloud.firestore {
  match /databases/{database}/documents {
    // Listings - authenticated users can create/update, only owner or admin can delete
    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Admin "Trash" for listings. Admin deletions move a listing here
    // (instead of hard-deleting) so an accidental bulk delete can be
    // restored within 30 days. Only admins may read it, put things in it,
    // or remove them - regular users must never see or touch trashed
    // listings. A scheduled Cloud Function purges entries past 30 days.
    match /deleted_listings/{listingId} {
      // Admins own the Trash: only they can read it, restore from it, or
      // permanently delete out of it.
      allow read, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      // A seller's own "Delete Permanently" also routes their listing here
      // (so admins keep oversight), so allow create either by an admin or by
      // the listing's own seller - but never for someone else's listing.
      allow create: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.resource.data.sellerId == request.auth.uid
      );
    }

    // User profiles are publicly readable, but writes were previously wide
    // open to ANY authenticated user on ANY user's document - meaning
    // anyone could self-grant themselves role:'admin', or edit someone
    // else's profile directly, bypassing the entire admin system. Fixed:
    match /users/{userId} {
      allow read: if true;

      // Creating your own doc (registration) is fine, but you can never
      // set your own role to admin at creation - admin can only ever be
      // granted by an existing admin via the admin panel.
      allow create: if request.auth != null && request.auth.uid == userId &&
        request.resource.data.role != 'admin';

      allow update: if request.auth != null && (
        // Admins can update any user (suspend, promote/demote, etc.)
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        // You can update your own doc, but never change your own role -
        // prevents self-promotion to admin via a direct write.
        (request.auth.uid == userId && request.resource.data.role == resource.data.role) ||
        // Leaving a review updates the reviewee's aggregate rating on
        // their doc - restricted to just these fields. ratingSum is a
        // running total (not shown in the UI) used to keep the average
        // race-free under a Firestore transaction.
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'ratingCount', 'ratingSum'])
      );

      // Only admins can hard-delete a user doc (e.g. the admin panel's
      // bulk-delete-users feature, cleaning up test/bad accounts). Regular
      // users never hard-delete their own doc - account removal elsewhere
      // in the app is a soft delete (status: 'deleted').
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Allow authenticated users to manage their own favorites
    match /favorites/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to read messages only in conversations they participate in
    // Messages have a conversationId field - check if user is in that conversation's participants
    match /messages/{messageId} {
      allow read: if request.auth != null && (
        // Direct participant check via receiverId/senderId - needed for
        // the unread-count badge, which queries by receiverId + read
        // directly rather than by a specific conversationId.
        request.auth.uid == resource.data.receiverId ||
        request.auth.uid == resource.data.senderId ||
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participants
      );
      // Blocked: if the receiver has the sender in their blockedUsers list,
      // the message is rejected server-side - not just hidden in the UI,
      // which anyone could bypass by calling the SDK directly.
      allow create: if request.auth != null &&
        !(request.auth.uid in get(/databases/$(database)/documents/users/$(request.resource.data.receiverId)).data.get('blockedUsers', []));
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.senderId || request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participants);
    }
    
    // Allow authenticated users to manage conversations they participate in
    match /conversations/{conversationId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.participants;
    }
    
    // Allow authenticated users to manage their own reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Anyone signed in can file a report, but only admins can view/manage
    // the list - these are meant to be reviewed by moderators, not
    // browsable by any authenticated user via the client SDK directly.
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Anyone (even signed out) can submit a contact message, but only
    // admins can read/manage the inbox - same reasoning as reports.
    match /contact_messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Audit trail for the admin data export feature - only admins can
    // create an entry (i.e. only by actually running an export) or read
    // the log of past exports. No update/delete - it's an audit trail,
    // not editable data.
    match /export_logs/{logId} {
      allow read, create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
