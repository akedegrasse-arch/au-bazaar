rules_version = "2";
service cloud.firestore {
  match /databases/{database}/documents {
    // Listings - authenticated users can create/update, only owner or admin can delete
    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Allow authenticated users to read user data
    // Allow authenticated users to write user data (needed for admin functions)
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Allowed users - authenticated users can read/add emails (for university validation)
    match /allowed_users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }
    
    // Allow authenticated users to manage their own favorites
    match /favorites/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to read messages only in conversations they participate in
    // Messages have a conversationId field - check if user is in that conversation's participants
    match /messages/{messageId} {
      allow read: if request.auth != null && 
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participants;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.senderId || request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participants);
    }
    
    // Allow authenticated users to manage conversations they participate in
    match /conversations/{conversationId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.participants;
    }
    
    // Allow authenticated users to manage their own reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Allow authenticated users to manage reports
    match /reports/{reportId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow anyone to submit contact messages (no auth required)
    match /contact_messages/{messageId} {
      allow create: if true;
      allow read, write: if request.auth != null;
    }
  }
}
